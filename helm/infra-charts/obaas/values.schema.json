{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] }
            ]
          },
          "description": "Image pull secrets must be a list (strings or {name: ...} objects), not a bare string. Use --set global.imagePullSecrets[0]=mysecret"
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "allowSameNamespace": { "type": "boolean" },
        "allowPublicIngress": { "type": "boolean" },
        "allowExternalEgress": { "type": "boolean" },
        "dns": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "namespaceSelector": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "podSelector": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "extraIngress": { "type": "array" },
        "extraEgress": { "type": "array" }
      }
    }
  }
}
